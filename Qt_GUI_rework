    def save_positions_callback(self):
        file_path, selected_filter = QFileDialog.getSaveFileName(
            self, "Save Positions", getcwd(), "Text Files (*.txt);;All Files (*)"
        )

        if file_path:
            if not file_path.endswith(".txt"):
                file_path += ".txt"

            strings: list[str] = []
            for i in range(self.position_widgets_n):
                xyz = self.position_widgets[i].get_position_float()
                xyz_str = [str(xyz[i]) if xyz[i] is not None else "" for i in range(3)]
