        for i in range(min([self.position_widgets_n, len(xyz_str)])):
            self.position_widgets[i].set_position_str(xyz_str[i])

        return

    def update_camera(self):
        # Read camera buffer
        ret, frame = self.camera.capture.read()

        center_x = frame.shape[1] // 2
        center_y = frame.shape[0] // 2

        cropped_frame = frame[
            center_y
            - self.image_crop_size[1] // 2 : center_y
            + self.image_crop_size[1] // 2,
            center_x
            - self.image_crop_size[0] // 2 : center_x
            + self.image_crop_size[0] // 2,
        ]

        # Detect rectangles
        obbs, confidences = [], []
        if self.draw_obb_checkbox.isChecked():
            obbs, confidences = self.ridge_model.run_detection(cropped_frame)

        if self.draw_obb_checkbox.isChecked() and obbs:
            # Draw rectangles
            for obb in obbs:
                xs = obb[:, 0].tolist()
                ys = obb[:, 1].tolist()
                xs.append(xs[0])
                ys.append(ys[0])
                for i in range(len(xs) - 1):
                    cv2.line(
                        img=cropped_frame,
                        pt1=(int(xs[i]), int(ys[i])),
                        pt2=(int(xs[i + 1]), int(ys[i + 1])),
                        color=(255, 0, 0),
                        thickness=2,
                    )

            first_ridge_center, last_ridge_center, _ = self.analyze_obbs(obbs)

            cv2.line(
                img=cropped_frame,
                pt1=[int(aaa) for aaa in first_ridge_center.tolist()],
                pt2=[int(aaa) for aaa in last_ridge_center.tolist()],
                color=(0, 255, 0),
                thickness=2,
            )

        # Convert to RGB
        rgb_image = cv2.cvtColor(cropped_frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb_image.shape
        bytes_per_line = ch * w

        qt_image = QImage(
            rgb_image.data,
            w,
            h,
            bytes_per_line,
            QImage.Format_RGB888,
        )

        scaled_pixmap = QPixmap.fromImage(qt_image).scaled(
            self.camera_feed.size(),
            Qt.KeepAspectRatio,
            Qt.SmoothTransformation,
        )

        self.camera_feed.setPixmap(scaled_pixmap)
        return
    
    def analyze_obbs(self, obbs):
        # Calculate mean rotation angle of each obb
        angles = [RidgeDetectionModel.get_box_angle(obb) for obb in obbs]
        angle_mean = np.mean(angles)

        # Rotate obbs to align with coordinate system
        rotated_obbs = [
            RidgeDetectionModel.rotate_tensor(obb, -angle_mean) for obb in obbs
        ]

        ridge_short_sides = [
            RidgeDetectionModel.get_box_short_side_points(obb)
            for obb in rotated_obbs
        ]
        ridge_long_sides = [
            RidgeDetectionModel.get_box_long_side_points(obb)
            for obb in rotated_obbs
        ]
        ridge_centers_x = [
            RidgeDetectionModel.get_box_center(obb)[0] for obb in rotated_obbs
        ]

        # Calculate distances between ridge centers
        # There can be missing ridges, so there is a chance to see a value equal 2*period or 3*period
        ridge_periods_pixel = [
            abs(ridge_centers_x[i] - ridge_centers_x[i + 1])
            for i in range(len(ridge_centers_x) - 1)
        ]
        ridge_period_mean_pixel = np.median(ridge_periods_pixel)

        ridge_length_pixel = (
            self.ridge_length_to_period_ratio * ridge_period_mean_pixel
        )

        ridge_center_coordinate_mean = np.mean(
            [np.mean([y1, y2]) for x1, y1, x2, y2 in ridge_long_sides]
        )

        first_box = np.array(rotated_obbs[0])
        last_box = np.array(rotated_obbs[-1])

        first_ridge_approx_center = np.mean(first_box, axis=0)
        first_ridge_avg_center = np.array([first_ridge_approx_center[0], ridge_center_coordinate_mean])

        last_ridge_approx_center = np.mean(last_box, axis=0)
        last_ridge_avg_center = np.array([last_ridge_approx_center[0], ridge_center_coordinate_mean])

        # Rotate back to original coordinate system
        first_ridge_avg_center = RidgeDetectionModel.rotate_vector(first_ridge_avg_center, angle_mean)
        last_ridge_avg_center = RidgeDetectionModel.rotate_vector(last_ridge_avg_center, angle_mean)

        return first_ridge_avg_center, last_ridge_avg_center, ridge_period_mean_pixel
    
    def get_chip_positions_callback(self):
        # Get first ridge position
        first_edge_found = False
        last_edge_found = False
        while not first_edge_found and not last_edge_found:
            ret, frame = self.camera.capture.read()

            center_x = frame.shape[1] // 2
            center_y = frame.shape[0] // 2

            cropped_frame = frame[
                center_y
                - self.image_crop_size[1] // 2 : center_y
                + self.image_crop_size[1] // 2,
                center_x
                - self.image_crop_size[0] // 2 : center_x
                + self.image_crop_size[0] // 2,
            ]

            obbs, confidences = self.ridge_model.run_detection(cropped_frame)
            if not first_edge_found:
                if not obbs:
                    x, y, z = self.gcode_sender.get_pos()
                    self.widget_x.target_edit.setText(f"{x+0.3:.2f}")
                    self.widget_x.move_to_target()
                    sleep(1)
                    continue

                first_obb_center, last_obb_center, period_pixels = self.analyze_obbs(obbs)
                if self.image_crop_size[1]/4 < first_obb_center[0] and first_obb_center[0] < self.image_crop_size[1]*3/4:

                    if self.pixels_to_mm_coeff is None:
                        self.pixels_to_mm_coeff = self.ridge_period / period_pixels
                    
                    xy_move_mm = (first_obb_center - self.zond_in_frame_coordinates)*self.pixels_to_mm_coeff
                    x_move_mm = xy_move_mm[0]
                    y_move_mm = xy_move_mm[1]

                    x, y, z = self.gcode_sender.get_pos()
                    self.widget_x.target_edit.setText(f"{x-x_move_mm:.2f}")
                    self.widget_x.move_to_target()
                    self.widget_y.target_edit.setText(f"{y-y_move_mm:.2f}")
                    self.widget_y.move_to_target()
                    sleep(1)

                    first_edge_found = True
                    last_edge_found = True
                
                elif self.image_crop_size[1]/4 > first_obb_center[0]:
                    x, y, z = self.gcode_sender.get_pos()
                    self.widget_x.target_edit.setText(f"{x-0.15:.2f}")
                    self.widget_x.move_to_target()
                    sleep(1)
                    continue
                elif first_obb_center[0] > self.image_crop_size[1]*3/4:
                    x, y, z = self.gcode_sender.get_pos()
                    self.widget_x.target_edit.setText(f"{x+0.15:.2f}")
                    self.widget_x.move_to_target()
                    sleep(1)
                    continue

        return
    
