        self.index = index
        self.go_to_callback = lambda: None
        self.put_position_callback = lambda: None

        self.setup_layout()
        return

    def setup_layout(self):
        layout = QHBoxLayout()
        self.setLayout(layout)

        label = QLabel(f"Position {self.index}")
        layout.addWidget(label)

        self.go_to_button = QPushButton("Go To")
        self.go_to_button.setFixedWidth(80)
        # self.go_to_button.clicked.connect(self.go_to_callback)
        layout.addWidget(self.go_to_button)

        self.put_button = QPushButton("Put")
        self.put_button.setFixedWidth(80)
        # self.put_button.clicked.connect(self.put_position_callback)
        layout.addWidget(self.put_button)

        self.position_x = QLineEdit(text="0.00")
        self.position_x.setText("0.00")
        self.position_x.setFixedWidth(80)
        layout.addWidget(self.position_x)

        self.position_y = QLineEdit(text="0.00")
        self.position_y.setText("0.00")
        self.position_y.setFixedWidth(80)
        layout.addWidget(self.position_y)

        self.position_z = QLineEdit(text="0.00")
        self.position_z.setText("0.00")
        self.position_z.setFixedWidth(80)
        layout.addWidget(self.position_z)
        return

    def go_to_connect(self, fn):
        self.go_to_button.clicked.connect(
            lambda: fn([self.position_x, self.position_y, self.position_z])
        )
        return

    def put_position_connect(self, fn):
        self.put_button.clicked.connect(
            lambda: fn([self.position_x, self.position_y, self.position_z])
        )
        return

    def get_position_float(self) -> list[float | None]:
        fields = [self.position_x, self.position_y, self.position_z]
        xyz_str = [field.text() for field in fields]

        return [
            float(xyz_str[i]) if is_float(xyz_str[i]) else None
            for i in range(len(xyz_str))
        ]

    def get_position_str(self) -> tuple[str, str, str]:
        fields = [self.position_x, self.position_y, self.position_z]
        xyz_str = [field.text() for field in fields]

        return xyz_str

    def set_position_float(
        self, pos: tuple[float | None, float | None, float | None]
    ) -> None:
        fields = [self.position_x, self.position_y, self.position_z]
        for i, field in enumerate(fields):
            if pos[i] is not None:
                field.setText(str(pos[i]))
        return

    def set_position_str(self, pos: tuple[str, str, str]) -> None:
        fields = [self.position_x, self.position_y, self.position_z]
        for i, field in enumerate(fields):
            field.setText(pos[i])
        return


