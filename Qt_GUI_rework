class Worker(QRunnable):
    """Worker thread.

    Inherits from QRunnable to handler worker thread setup, signals and wrap-up.

    :param callback: The function callback to run on this worker thread.
                     Supplied args and kwargs will be passed through to the runner.
    :type callback: function
    :param args: Arguments to pass to the callback function
    :param kwargs: Keywords to pass to the callback function
    """

    def __init__(self, fn, *args, **kwargs):
        super().__init__()
        self.fn = fn
        self.args = args
        self.kwargs = kwargs

    @Slot()
    def run(self):
        """Initialise the runner function with passed args, kwargs."""
        self.fn(*self.args, **self.kwargs)


class AxisControlWidget(QWidget):
    def __init__(self, axis_name: str, apparatus: Apparatus) -> None:
        super().__init__()
        self.axis_name = axis_name.upper()
        self.apparatus = apparatus
        self.target_position_refresh_callback: callable | None = None
        self.target_pos = 0.0

        self.setup_layout()
        return

    def setup_layout(self) -> None:
        layout = QHBoxLayout()

        layout.addWidget(QLabel(self.axis_name))

        self.target_edit = QLineEdit("0.00")
        self.target_edit.setFixedWidth(80)
        self.target_edit.returnPressed.connect(self.move_to_target_callback)
        layout.addWidget(self.target_edit)

        self.minus_btn = QPushButton("-")
        self.minus_btn.setFixedWidth(40)
        self.minus_btn.clicked.connect(lambda: self.move_increment_callback("-"))
        layout.addWidget(self.minus_btn)

        self.plus_btn = QPushButton("+")
        self.plus_btn.setFixedWidth(40)
        self.plus_btn.clicked.connect(lambda: self.move_increment_callback("+"))
        layout.addWidget(self.plus_btn)

        self.step_edit = QLineEdit("1.0")
        self.step_edit.setFixedWidth(60)
        layout.addWidget(self.step_edit)

        self.setLayout(layout)
        return

    def set_apparatus(self, apparatus: Apparatus) -> None:
        self.apparatus = apparatus
        return

    def set_target_refresh_callback_function(self, fn: callable) -> None:
        self.target_position_refresh_callback = fn

    def move_increment_callback(self, sign: str):
        try:
            axis_index = {"X": 0, "Y": 1, "Z": 2}[self.axis_name.upper()]

            reletive_position = [0.0, 0.0, 0.0]
            if sign == "+":
                reletive_position[axis_index] = float(self.step_edit.text())
            else:
                reletive_position[axis_index] = -float(self.step_edit.text())

            self.apparatus.set_terget_reletive_to_current(reletive_position)
            self.move_to_target()
        except Exception as e:
            QMessageBox.warning(self, "Error", str(e))

    def move_to_target_callback(self):
        value = self.target_edit.text()
        if is_float(value):
            self.apparatus.set_target_position_piecewice(
                self.axis_name, float(self.target_edit.text())
            )
        else:
            raise Exception(f"Unknown position value: {value}")
        self.move_to_target()
        return

    def move_to_target(self):
        try:
            self.apparatus.move_to_target_position()
            self.target_position_refresh_callback()
        except Exception as e:
            QMessageBox.warning(self, "Error", str(e))
        return


class MainWindow(QMainWindow):
    def __init__(self) -> None:
        super().__init__()
        self.apparatus: Apparatus | None = None

        self.threadpool = QThreadPool()
        thread_count = self.threadpool.maxThreadCount()
        print(f"Multithreading with maximum {thread_count} threads")

        self.setup_layout()
        return

    def setup_layout(self) -> None:
        self.setWindowTitle("Jog panel")
        self.setGeometry(100, 100, 300, 300)

        main_widget = QWidget()
        self.setCentralWidget(main_widget)
        main_layout = QVBoxLayout(main_widget)

        splitter = QSplitter(Qt.Horizontal)

        ######

        controls_widget = QWidget()
        controls_layout = QVBoxLayout()

        self.widget_x = AxisControlWidget("X", self.apparatus)
        controls_layout.addWidget(self.widget_x)
        self.widget_x.set_target_refresh_callback_function(
            self.refresh_positions_callback
        )

        self.widget_y = AxisControlWidget("Y", self.apparatus)
        controls_layout.addWidget(self.widget_y)
        self.widget_y.set_target_refresh_callback_function(
            self.refresh_positions_callback
        )

        self.widget_z = AxisControlWidget("Z", self.apparatus)
        controls_layout.addWidget(self.widget_z)
        self.widget_z.set_target_refresh_callback_function(
            self.refresh_positions_callback
        )

        ###

        btn_layout = QHBoxLayout()

        self.connect_btn = QPushButton("Connect")
        self.connect_btn.clicked.connect(self.connect_apparatus_callback)
        btn_layout.addWidget(self.connect_btn)

        self.home_btn = QPushButton("Home All")
        self.home_btn.clicked.connect(self.home_all_callback)
        self.home_btn.setEnabled(False)
        btn_layout.addWidget(self.home_btn)

        self.refresh_btn = QPushButton("Refresh Positions")
        self.refresh_btn.clicked.connect(self.refresh_positions_callback)
        self.refresh_btn.setEnabled(False)
        btn_layout.addWidget(self.refresh_btn)

        btn_layout.addStretch()
        controls_layout.addLayout(btn_layout)

        controls_widget.setLayout(controls_layout)

        self.draw_obb_checkbox = QCheckBox("Draw OBB")
        controls_layout.addWidget(self.draw_obb_checkbox)

        ###

        btn_layout = QHBoxLayout()

        self.deduce_last_ridge_position_btn = QPushButton("Zond is on the first ridge")
        self.deduce_last_ridge_position_btn.clicked.connect(self.deduce_last_ridge_position_callback)
        btn_layout.addWidget(self.deduce_last_ridge_position_btn)

        self.autoapply_btn = QPushButton("Run")
        self.autoapply_btn.clicked.connect(self.run_btn_callback)
        btn_layout.addWidget(self.autoapply_btn)

        btn_layout.addStretch()
        controls_layout.addLayout(btn_layout)

        ###

        go_to_ridge_layout = QHBoxLayout()
        self.ridge_index_edit = QLineEdit()
        self.go_to_ridge_btn = QPushButton("Go to ridge")
        self.go_to_ridge_btn.clicked.connect(self.go_to_ridge_callback)
        go_to_ridge_layout.addWidget(self.ridge_index_edit)
        go_to_ridge_layout.addWidget(self.go_to_ridge_btn)
        controls_layout.addLayout(go_to_ridge_layout)

        measure_backlask_layout = QHBoxLayout()
        self.measure_backlask_edit = QLineEdit()
        self.measure_backlask_btn = QPushButton("Measure basklash")
        self.measure_backlask_btn.clicked.connect(self.measure_backlask_callback)
        measure_backlask_layout.addWidget(self.measure_backlask_edit)
        measure_backlask_layout.addWidget(self.measure_backlask_btn)
        controls_layout.addLayout(measure_backlask_layout)

        controls_layout.addStretch()

        ######

        camera_widget = QWidget()
        camera_layout = QVBoxLayout()
        camera_widget.setLayout(camera_layout)

        self.camera_feed_widget = QLabel("Camera")
        self.camera_feed_widget.setAlignment(Qt.AlignCenter)
        camera_layout.addWidget(self.camera_feed_widget)

        self.camera_timer = QTimer()
        self.camera_timer.timeout.connect(self.update_camera_callback)

        splitter.addWidget(controls_widget)
        splitter.addWidget(camera_widget)

        main_layout.addWidget(splitter)
        return

    def home_all(self):
        self.apparatus.home()
        self.refresh_positions_callback()
        return

    def refresh_positions(self):
        x, y, z = self.apparatus.get_current_position()
        self.widget_x.target_edit.setText(f"{x:.2f}")
        self.widget_y.target_edit.setText(f"{y:.2f}")
        self.widget_z.target_edit.setText(f"{z:.2f}")
        return

    def connect_apparatus(self) -> None:
        try:
            self.apparatus = Apparatus()
            self.widget_x.set_apparatus(self.apparatus)
            self.widget_y.set_apparatus(self.apparatus)
            self.widget_z.set_apparatus(self.apparatus)
            self.camera_timer.start(100)
        except Exception as e:
            QMessageBox.critical(self, "Connection Error", str(e))
        return

    def connect_apparatus_callback(self):
        self.connect_apparatus()
        self.home_btn.setEnabled(True)
        self.refresh_btn.setEnabled(True)
        return

    def home_all_callback(self):
        self.home_all()
        return

    def refresh_positions_callback(self):
        self.refresh_positions()
        return

    def update_camera_callback(self) -> None:

        if self.apparatus is None:
            raise Exception("Camera not connected")

        framedata = self.apparatus.get_camera_frame(
            False,
            self.draw_obb_checkbox.isChecked(),
        )
        frame, first_ridge_center, last_ridge_center, ridge_period_in_pixels = framedata

        # Convert to RGB
        rgb_image = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb_image.shape
        bytes_per_line = ch * w

        qt_image = QImage(
            rgb_image.data,
            w,
            h,
            bytes_per_line,
            QImage.Format_RGB888,
        )

        scaled_pixmap = QPixmap.fromImage(qt_image).scaled(
            self.camera_feed_widget.size(),
            Qt.KeepAspectRatio,
            Qt.SmoothTransformation,
        )

        self.camera_feed_widget.setPixmap(scaled_pixmap)
        return
    
    def deduce_last_ridge_position_callback(self) -> None:
        worker = Worker(self.apparatus.deduce_last_ridge_position)
        self.threadpool.start(worker)
        return

    def run_btn_callback(self) -> None:
        worker = Worker(self.apparatus.run)
        self.threadpool.start(worker)
        return
    
    def go_to_ridge_callback(self) -> None:
        nth = int(self.ridge_index_edit.text())
        worker = Worker(self.apparatus.go_to_nth_ridge_center, nth)
        self.threadpool.start(worker)
        return
    
    def measure_backlask_callback(self) -> None:
        nth = int(self.measure_backlask_edit.text())
        worker = Worker(self.apparatus.measure_basklash, nth)
        self.threadpool.start(worker)
        return

    def closeEvent(self, event):
        if self.apparatus is not None:
            self.apparatus.close()
        event.accept()
        return


if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = MainWindow()
    window.show()
    sys.exit(app.exec())
